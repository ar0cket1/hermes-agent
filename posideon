#!/usr/bin/env python3
"""
Posideon Agent CLI Launcher

This is a convenience wrapper to launch the Hermes CLI in Posideon skin mode.
Usage: ./posideon [options]
"""

if __name__ == "__main__":
    import os

    os.environ["HERMES_CLI_SKIN"] = "posideon"
    from cli import main
    import fire

    fire.Fire(main)
